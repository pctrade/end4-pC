{
    "id": "battery_plugin",
    "name": "Battery Status Plugin",
    "description": "A declarative battery status indicator",
    "defaultWidth": 200,
    "defaultHeight": 100,
    "desktopWidget": {
        "blur": true,
        "type": "Rectangle",
        "props": {
            "radius": "Appearance.rounding.large",
            "color": "Appearance.colors.colLayer0",
            "width": 200,
            "height": 100
        },
        "children": [
            {
                "type": "Row",
                "props": {
                    "anchors.centerIn": "parent",
                    "spacing": 10
                },
                "children": [
                    {
                        "type": "MaterialSymbol",
                        "props": {
                            "text": "battery_full",
                            "font.pixelSize": 36,
                            "color": "Appearance.colors.colOnLayer0"
                        }
                    },
                    {
                        "type": "StyledText",
                        "props": {
                            "font.pixelSize": 36,
                            "font.weight": 600,
                            "color": "Appearance.colors.colOnLayer0"
                        },
                        "bindings": {
                            "text": "Battery.percentage"
                        }
                    }
                ]
            }
        ]
    }
}
